<embed color="#21D067">
    <title
        th:url="${'https://modrinth.com/mod/' + project.slug + '/versions'}"
        th:text="${'Project update: ' + project.title}"
     />
    <description th:text="${'Version name: ' + version.name}" />
    <thumbnail th:url="${project.iconUrl}" />
    <field
        th:each="i : ${version.files}"
        th:attr="name=${i.filename}"
        inline="true"
        th:text="|[download](${i.url})|"
    />
</embed>
